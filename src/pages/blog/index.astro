---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";

type BlogEntry = CollectionEntry<"blog">;

const posts = (await getCollection("blog"))
  .filter((post) => post.data.type !== "project")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getPostHref = (post: BlogEntry) =>
  `/blog/${post.id.replace(/\.mdx?$/, "")}/`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title="Notas técnicas | Edson Lopes"
      description="Notas técnicas sobre confiabilidade, manutenção industrial, gestão de ativos, dados e decisão."
    />

    <style>
      .notes-page {
        width: min(980px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 4.5rem 0 6rem;
      }

      .notes-header {
        max-width: 760px;
        margin-bottom: 3rem;
      }

      .eyebrow {
        margin: 0 0 0.9rem;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .notes-header h1 {
        margin: 0;
        color: var(--text);
        font-size: clamp(2.6rem, 6vw, 4.6rem);
        line-height: 1;
        letter-spacing: -0.06em;
      }

      .notes-header p {
        max-width: 680px;
        margin: 1.4rem 0 0;
        color: #b7c7dc;
        font-size: 1.08rem;
        line-height: 1.75;
      }

      .notes-list {
        display: grid;
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .note-card {
        display: block;
        padding: 1.4rem 1.5rem;
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.02);
        text-decoration: none;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease;
      }

      .note-card:hover {
        transform: translateY(-2px);
        border-color: rgba(245, 158, 11, 0.45);
        background: rgba(255, 255, 255, 0.035);
      }

      .note-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
        margin-bottom: 0.8rem;
        color: var(--accent);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .note-meta .reading-time {
        color: var(--muted);
        font-weight: 600;
        letter-spacing: 0;
        text-transform: none;
      }

      .note-card h2 {
        margin: 0 0 0.75rem;
        color: var(--text);
        font-size: clamp(1.25rem, 3vw, 1.65rem);
        line-height: 1.2;
        letter-spacing: -0.035em;
      }

      .note-card p {
        max-width: 780px;
        margin: 0;
        color: #a9bad0;
        font-size: 0.98rem;
        line-height: 1.65;
      }

      .note-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 1rem;
      }

      .note-tags span {
        padding: 0.3rem 0.55rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.76rem;
        line-height: 1;
      }

      .empty-state {
        padding: 1.5rem;
        border: 1px solid var(--border);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.02);
        color: var(--muted);
      }

      @media (max-width: 640px) {
        .notes-page {
          width: min(100% - 1.25rem, 980px);
          padding: 3rem 0 4rem;
        }

        .note-card {
          padding: 1.15rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main class="notes-page">
      <header class="notes-header">
        <p class="eyebrow">Notas técnicas</p>

        <h1>Confiabilidade, manutenção e decisão.</h1>

        <p>
          Reflexões e estudos aplicados sobre manutenção industrial,
          confiabilidade, gestão de ativos, análise de dados e modelos de apoio
          à decisão.
        </p>
      </header>

      {
        posts.length > 0 ? (
          <section aria-label="Lista de notas técnicas">
            <ul class="notes-list">
              {posts.map((post) => (
                <li>
                  <a class="note-card" href={getPostHref(post)}>
                    <div class="note-meta">
                      <FormattedDate date={post.data.pubDate} />

                      {post.data.readingTime && (
                        <span class="reading-time">{post.data.readingTime}</span>
                      )}
                    </div>

                    <h2>{post.data.title}</h2>

                    {post.data.description && <p>{post.data.description}</p>}

                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="note-tags">
                        {post.data.tags.slice(0, 4).map((tag) => (
                          <span>{tag}</span>
                        ))}
                      </div>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ) : (
          <p class="empty-state">
            Nenhuma nota técnica publicada ainda.
          </p>
        )
      }
    </main>

    <Footer />
  </body>
</html>