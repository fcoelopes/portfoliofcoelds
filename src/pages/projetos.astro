---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title="Projetos | Edson Lopes"
      description="Projetos técnicos de Edson Lopes."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="page-hero">
        <p class="eyebrow">Portfólio técnico</p>
        <h1>Projetos</h1>
        <p>
          Projetos em engenharia, manutenção, confiabilidade, dados e software.
        </p>
      </section>

      <section class="cards two">
        <article class="card">
          <h2>RCM com LLM</h2>
          <p>
            Assistente para apoiar análises de Manutenção Centrada na
            Confiabilidade.
          </p>
          <span>RCM · LLM · Confiabilidade</span>
        </article>

        <article class="card">
          <h2>Análise RAM e RBD</h2>
          <p>
            Modelagem de sistemas reparáveis e não reparáveis para estudos RAM.
          </p>
          <span>RAM · RBD · Weibull · Crow-AMSAA</span>
        </article>

        <article class="card">
          <h2>PHM e Vibração</h2>
          <p>
            Uso de dados de vibração, temperatura e corrente em manutenção
            preditiva.
          </p>
          <span>PHM · Python · Cox PH</span>
        </article>

        <article class="card">
          <h2>Sistema de Controle de EPIs</h2>
          <p>
            Software para controle, rastreabilidade e gestão de entrega de EPIs.
          </p>
          <span>Python · Gestão · EPI</span>
        </article>

        {/* Projetos fora do escopo de confiabilidade/dados industriais — removidos do portfólio principal */}
      </section>
    </main>

    <Footer />
  </body>
</html>
