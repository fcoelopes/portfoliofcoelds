---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title="Currículo | Edson Lopes"
      description="Currículo profissional de Edson Lopes: confiabilidade, gestão de ativos, PCM, preditiva, dados e software."
    />
  </head>

  <body>
    <Header />

    <main>
      <section class="resume-hero">
        <div>
          <p class="kicker">Currículo</p>

          <h1>Edson Lopes</h1>

          <p class="hero-role">Consultor de Confiabilidade N1</p>

          <p class="resume-lead">
            Profissional com mais de 15 anos de experiência industrial em
            operação, manutenção, PCM, manutenção preditiva, confiabilidade e
            gestão de ativos.
          </p>

          <p class="resume-copy">
            Minha trajetória combina vivência prática em chão de fábrica,
            manutenção técnica, planejamento, confiabilidade e análise de dados
            aplicada à decisão sobre ativos industriais.
          </p>

          <div class="page-actions">
            <a class="button primary" href="/curriculo-edson-lopes.pdf">
              Baixar currículo em PDF
            </a>

            <a
              class="button secondary"
              href="https://www.linkedin.com/in/franciscoedsonlopessilva"
              target="_blank"
              rel="noreferrer"
            >
              Ver LinkedIn
            </a>

            <a class="button secondary" href="/projetos"> Ver projetos </a>
          </div>
        </div>

        <aside class="resume-panel">
          <p class="panel-label">Resumo profissional</p>

          <div class="resume-fact">
            <strong>15+</strong>
            <span>Anos de experiência industrial</span>
          </div>

          <div class="resume-fact">
            <strong>N1</strong>
            <span>Consultor de Confiabilidade Compass</span>
          </div>

          <div class="resume-fact">
            <strong>14+</strong>
            <span>Anos na The HEINEKEN Company</span>
          </div>

          <div class="resume-fact">
            <strong>Atual</strong>
            <span>ArcelorMittal Pecém</span>
          </div>
        </aside>
      </section>

      <section class="section resume-section">
        <div class="section-heading">
          <p class="kicker">Experiência</p>

          <h2>Experiência construída em ambientes industriais reais.</h2>

          <p>
            Atuação em siderurgia, alimentos e bebidas, operação industrial,
            manutenção, PCM, preditiva, confiabilidade e gestão de ativos.
          </p>
        </div>

        <div class="experience-list">
          <article class="experience-card current">
            <div>
              <p class="experience-period">2025 · Atual</p>
              <h3>ArcelorMittal Aços Planos</h3>
              <span>Técnico de Planejamento e Programação Preditiva</span>
            </div>

            <p>
              Atuação em planejamento, programação e suporte à manutenção
              preditiva no contexto industrial da ArcelorMittal Pecém.
            </p>
          </article>

          <article class="experience-card">
            <div>
              <p class="experience-period">2024 · 2025</p>
              <h3>Compet Engenharia</h3>
              <span>Técnico de Apoio Master</span>
            </div>

            <p>
              Apoio às equipes de confiabilidade e manutenção preditiva, com
              interface entre áreas e suporte à execução de técnicas avançadas
              de manutenção.
            </p>
          </article>

          <article class="experience-card">
            <div>
              <p class="experience-period">2010 · 2024</p>
              <h3>The HEINEKEN Company</h3>
              <span>Operação · Utilidades · Instrumentação · PCM</span>
            </div>

            <p>
              Trajetória de mais de 14 anos passando por operação industrial,
              utilidades, instalações industriais, manutenção e planejamento de
              manutenção.
            </p>
          </article>
        </div>
      </section>

      <section class="section resume-section">
        <div class="section-heading">
          <p class="kicker">Competências</p>

          <h2>Competências organizadas por aplicação.</h2>

          <p>
            Em vez de uma lista genérica de ferramentas, estas são as frentes em
            que aplico conhecimento técnico para apoiar decisões de manutenção e
            gestão de ativos.
          </p>
        </div>

        <div class="resume-capabilities">
          <article>
            <span>01</span>
            <h3>Confiabilidade</h3>
            <ul>
              <li>RCM e FMEA</li>
              <li>RAM, RBD, FTA, LDA e RGA</li>
              <li>Análise de falhas e criticidade</li>
              <li>Sistemas reparáveis e não reparáveis</li>
            </ul>
          </article>

          <article>
            <span>02</span>
            <h3>PCM & Preditiva</h3>
            <ul>
              <li>Planejamento e programação</li>
              <li>Gestão de sobressalentes</li>
              <li>Gestão de paradas</li>
              <li>Técnicas avançadas de manutenção</li>
            </ul>
          </article>

          <article>
            <span>03</span>
            <h3>Dados & Software</h3>
            <ul>
              <li>Python para análise de dados</li>
              <li>SQL</li>
              <li>Modelagem estatística</li>
              <li>Ferramentas técnicas para engenharia</li>
            </ul>
          </article>

          <article>
            <span>04</span>
            <h3>Gestão de Ativos</h3>
            <ul>
              <li>ISO 55000</li>
              <li>Priorização de ativos</li>
              <li>Tomada de decisão</li>
              <li>Indicadores e suporte à gestão</li>
            </ul>
          </article>
        </div>
      </section>

      <section class="section resume-section">
        <div class="section-heading">
          <p class="kicker">Formação & Certificações</p>

          <h2>Base técnica, gestão e dados.</h2>
        </div>

        <div class="education-grid">
          <article>
            <span>Formação técnica</span>
            <h3>Automação Industrial</h3>
            <p>Instituto Federal do Ceará · IFCE</p>
          </article>

          <article>
            <span>Graduação</span>
            <h3>Administração</h3>
            <p>Universidade de Fortaleza · UNIFOR · <em>Em andamento</em></p>
          </article>

          <article>
            <span>Graduação</span>
            <h3>Ciência de Dados</h3>
            <p>
              UNINTER Centro Universitário Internacional · <em>Em andamento</em>
            </p>
          </article>

          <article>
            <span>Certificação</span>
            <h3>Consultor de Confiabilidade N1</h3>
            <p>Compass</p>
          </article>

          <article>
            <span>Certificação</span>
            <h3>Facilitador RCM</h3>
            <p>Manutenção Centrada na Confiabilidade</p>
          </article>

          <article>
            <span>Certificação</span>
            <h3>Gestão de Ativos</h3>
            <p>Curso intensivo em gestão de ativos</p>
          </article>
        </div>
      </section>

      <section class="section resume-cta">
        <div>
          <p class="kicker">Contato</p>

          <h2>Vamos conversar sobre confiabilidade, manutenção e decisão?</h2>

          <p>
            Veja meu LinkedIn, baixe o currículo em PDF ou conheça os projetos
            que conectam confiabilidade, dados e software.
          </p>
        </div>

        <div class="resume-cta-actions">
          <a class="button primary" href="/curriculo-edson-lopes.pdf">
            Baixar CV
          </a>

          <a
            class="button secondary"
            href="https://www.linkedin.com/in/franciscoedsonlopessilva"
            target="_blank"
            rel="noreferrer"
          >
            LinkedIn
          </a>

          <a class="button secondary" href="/projetos"> Projetos </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
