---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  tags,
  readingTime,
  type,
  category,
  status,
  progress,
} = Astro.props as Props;

const isProject = type === "project";
---

<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} />

    <style>
      .post-wrap {
        width: min(760px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 4.5rem 0 6rem;
      }

      .sep {
        color: var(--border-strong);
      }

      /* ─────────────────────────────
         Header editorial padrão
      ───────────────────────────── */

      .editorial-header {
        margin-bottom: 3rem;
      }

      .editorial-kicker {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
        margin: 0 0 1.25rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .editorial-kicker span {
        padding: 0.28rem 0.55rem;
        border: 1px solid rgba(245, 158, 11, 0.35);
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.07);
        color: var(--accent);
        font-size: 0.72rem;
        letter-spacing: 0.06em;
      }

      .editorial-header h1 {
        margin: 0;
        color: var(--text);
        font-size: clamp(2.8rem, 7vw, 5rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
      }

      .editorial-description {
        margin: 1.5rem 0 0;
        color: #b7c7dc;
        font-size: clamp(1.15rem, 2vw, 1.35rem);
        line-height: 1.65;
      }

      .editorial-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 1.4rem;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 1.5rem 0 0;
        padding: 0;
        list-style: none;
      }

      .post-tags li {
        padding: 0.35rem 0.65rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.025);
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1;
      }

      /* ─────────────────────────────
         Header de projeto
      ───────────────────────────── */

      .project-post-header {
        width: min(900px, calc(100vw - 2rem));
        margin: 0 50% 3rem;
        transform: translateX(-50%);
        padding: 2rem;
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        background:
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.05),
            rgba(255, 255, 255, 0.018)
          );
      }

      .project-kicker {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
        margin-bottom: 2rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .project-pill {
        padding: 0.35rem 0.6rem;
        border: 1px solid rgba(245, 158, 11, 0.4);
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.08);
        color: var(--accent);
        font-size: 0.74rem;
        letter-spacing: 0.06em;
      }

      .project-post-header h1 {
        max-width: 900px;
        margin: 0;
        color: var(--text);
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: 0.98;
        letter-spacing: -0.065em;
      }

      .project-lead {
        max-width: 760px;
        margin: 1.5rem 0 0;
        color: #b7c7dc;
        font-size: clamp(1.08rem, 2vw, 1.25rem);
        line-height: 1.7;
      }

      .project-post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 1.6rem;
        color: var(--muted);
        font-size: 0.86rem;
      }

      .project-progress {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }

      .project-progress-top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.65rem;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
      }

      .project-progress-top strong {
        color: var(--accent);
      }

      .project-progress-track {
        height: 0.55rem;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
      }

      .project-progress-track span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: var(--accent);
      }

      /* ─────────────────────────────
         Hero image
      ───────────────────────────── */

      .post-hero {
        width: min(960px, calc(100vw - 2rem));
        margin: 0 50% 3rem;
        transform: translateX(-50%);
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--surface-2);
      }

      .post-hero img {
        width: 100%;
        display: block;
      }

      /* ─────────────────────────────
         Resumo das notas
      ───────────────────────────── */

      .post-summary {
        margin: 0 0 3rem;
        padding: 1.25rem 1.5rem;
        border: 1px solid var(--border);
        border-left: 4px solid var(--accent);
        border-radius: 0.85rem;
        background: rgba(245, 158, 11, 0.055);
      }

      .post-summary strong {
        display: block;
        margin-bottom: 0.45rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.09em;
        text-transform: uppercase;
      }

      .post-summary p {
        margin: 0;
        color: #b7c7dc;
        font-size: 1rem;
        line-height: 1.7;
      }

      /* ─────────────────────────────
         Prose estilo Medium
      ───────────────────────────── */

      .prose {
        max-width: 720px;
        margin: 0 auto;
        color: #d4e1f1;
        font-size: 1.18rem;
        line-height: 1.9;
        overflow-wrap: break-word;
      }

      .prose > *:first-child {
        margin-top: 0;
      }

      .prose p {
        margin: 0 0 1.8rem;
        color: #c8d3e0;
        font-size: 1.18rem;
        line-height: 1.9;
      }

      .prose h2 {
        margin: 4rem 0 1.25rem;
        padding: 0;
        border-left: 0;
        color: var(--text);
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.08;
        letter-spacing: -0.055em;
      }

      .prose h3 {
        margin: 3rem 0 1rem;
        color: var(--text);
        font-size: clamp(1.45rem, 3vw, 1.8rem);
        line-height: 1.2;
        letter-spacing: -0.04em;
      }

      .prose h4 {
        margin: 2.25rem 0 0.8rem;
        color: var(--text);
        font-size: 1.15rem;
        line-height: 1.35;
      }

      .prose strong {
        color: #f1f5f9;
        font-weight: 700;
      }

      .prose em {
        color: #dbe7f5;
      }

      .prose ul,
      .prose ol {
        margin: 0 0 2rem;
        padding-left: 1.5rem;
      }

      .prose li {
        margin-bottom: 0.75rem;
        color: #c8d3e0;
        font-size: 1.12rem;
        line-height: 1.8;
      }

      .prose ul li::marker,
      .prose ol li::marker {
        color: var(--accent);
      }

      .prose blockquote {
        margin: 2.8rem 0;
        padding: 0.2rem 0 0.2rem 1.5rem;
        border-left: 4px solid var(--accent);
        background: transparent;
        border-radius: 0;
      }

      .prose blockquote p {
        margin: 0;
        color: #f1f5f9;
        font-size: clamp(1.35rem, 3vw, 1.75rem);
        line-height: 1.55;
        font-style: normal;
        letter-spacing: -0.025em;
      }

      .prose hr {
        width: 5rem;
        margin: 3.5rem auto;
        border: none;
        border-top: 1px solid var(--border);
      }

      .prose a {
        color: #fbbf24;
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-thickness: 1px;
        text-decoration-color: rgba(251, 191, 36, 0.45);
      }

      .prose a:hover {
        text-decoration-color: #fbbf24;
      }

      .prose code {
        padding: 0.15em 0.35em;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface-2);
        color: var(--accent);
        font-size: 0.88em;
      }

      .prose pre {
        width: min(920px, calc(100vw - 2rem));
        margin: 2.5rem 50%;
        transform: translateX(-50%);
        padding: 1.4rem 1.5rem;
        border: 1px solid var(--border);
        border-radius: 0.9rem;
        background: var(--surface-2);
        overflow-x: auto;
      }

      .prose pre code {
        padding: 0;
        border: 0;
        background: none;
        color: var(--text);
      }

      .prose img {
        width: min(960px, calc(100vw - 2rem));
        max-width: none;
        display: block;
        margin: 3rem 50%;
        transform: translateX(-50%);
        border-radius: 0.9rem;
        border: 1px solid var(--border);
      }

      .prose figure {
        width: min(960px, calc(100vw - 2rem));
        margin: 3rem 50%;
        transform: translateX(-50%);
      }

      .prose figure img {
        width: 100%;
        margin: 0;
        transform: none;
      }

      .prose figcaption {
        margin-top: 0.8rem;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.5;
        text-align: center;
      }

      .prose table {
        display: block;
        width: min(920px, calc(100vw - 2rem));
        margin: 2.5rem 50%;
        transform: translateX(-50%);
        border-collapse: collapse;
        overflow-x: auto;
        font-size: 0.95rem;
      }

      .prose th,
      .prose td {
        padding: 0.85rem 1rem;
        border: 1px solid var(--border);
        text-align: left;
        vertical-align: top;
      }

      .prose th {
        background: var(--surface-2);
        color: var(--text);
        font-weight: 700;
      }

      .prose td {
        color: #c8d3e0;
      }

      .prose tr:nth-child(even) td {
        background: rgba(255, 255, 255, 0.018);
      }

      /* ─────────────────────────────
         Blocos opcionais para Markdown
      ───────────────────────────── */

      .prose .technical-note,
      .prose .decision-note,
      .prose .warning-note {
        margin: 2.4rem 0;
        padding: 1.2rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 0.85rem;
        background: rgba(255, 255, 255, 0.025);
      }

      .prose .decision-note {
        border-left: 4px solid var(--accent);
      }

      .prose .warning-note {
        border-left: 4px solid #f97316;
      }

      .prose .technical-note strong,
      .prose .decision-note strong,
      .prose .warning-note strong {
        color: var(--accent);
      }

      /* ─────────────────────────────
         Responsivo
      ───────────────────────────── */

      @media (max-width: 640px) {
        .post-wrap {
          width: min(100% - 1.25rem, 760px);
          padding: 3rem 0 4rem;
        }

        .editorial-header h1,
        .project-post-header h1 {
          font-size: clamp(2.3rem, 11vw, 3.4rem);
        }

        .editorial-description,
        .project-lead {
          font-size: 1.05rem;
        }

        .project-post-header {
          padding: 1.35rem;
        }

        .prose {
          max-width: 100%;
          font-size: 1.05rem;
          line-height: 1.78;
        }

        .prose p,
        .prose li {
          font-size: 1.05rem;
          line-height: 1.78;
        }

        .prose h2 {
          margin-top: 3rem;
        }

        .prose blockquote p {
          font-size: 1.2rem;
        }

        .post-summary {
          padding: 1rem 1.1rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <article class="post-wrap">
        {
          isProject ? (
            <header class="project-post-header">
              <div class="project-kicker">
                <span>{category ?? "Projeto aplicado"}</span>
                {status && <span class="project-pill">{status}</span>}
              </div>

              <h1>{title}</h1>

              {description && <p class="project-lead">{description}</p>}

              <div class="project-post-meta">
                <FormattedDate date={pubDate} />

                {readingTime && (
                  <>
                    <span class="sep">·</span>
                    <span>{readingTime}</span>
                  </>
                )}

                {updatedDate && (
                  <>
                    <span class="sep">·</span>
                    <span>
                      Atualizado em <FormattedDate date={updatedDate} />
                    </span>
                  </>
                )}
              </div>

              {typeof progress === "number" && (
                <div
                  class="project-progress"
                  aria-label={`Progresso do projeto: ${progress}%`}
                >
                  <div class="project-progress-top">
                    <span>Progresso do projeto</span>
                    <strong>{progress}%</strong>
                  </div>

                  <div class="project-progress-track">
                    <span style={`width: ${progress}%`}></span>
                  </div>
                </div>
              )}
            </header>
          ) : (
            <header class="editorial-header">
              <p class="editorial-kicker">
                Nota técnica
                {tags && tags.length > 0 && <span>{tags[0]}</span>}
              </p>

              <h1>{title}</h1>

              {description && <p class="editorial-description">{description}</p>}

              <div class="editorial-meta">
                <FormattedDate date={pubDate} />

                {readingTime && (
                  <>
                    <span class="sep">·</span>
                    <span>{readingTime}</span>
                  </>
                )}

                {updatedDate && (
                  <>
                    <span class="sep">·</span>
                    <span>
                      Atualizado em <FormattedDate date={updatedDate} />
                    </span>
                  </>
                )}
              </div>

              {tags && tags.length > 1 && (
                <ul class="post-tags" aria-label="Tags do artigo">
                  {tags.slice(1).map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </header>
          )
        }

        {
          heroImage && (
            <div class="post-hero">
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt={heroImageAlt ?? ""}
              />
            </div>
          )
        }

        {
          !isProject && description && (
            <section class="post-summary" aria-label="Resumo do artigo">
              <strong>Resumo</strong>
              <p>{description}</p>
            </section>
          )
        }

        <div class="prose">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>